APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=${{Postgres.DATABASE_URL}}
TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret
TELEGRAM_ADMIN_IDS=123456789
ALLOW_DEV_AUTH=false
CORS_ORIGINS=https://your-railway-domain.up.railway.app
FREE_DAILY_WORD_LIMIT=10
DEFAULT_TIMEZONE=Asia/Tashkent
SEED_DEFAULT_WORDS=true
MANUAL_PAYMENT_AMOUNT_UZS=49000
MANUAL_PAYMENT_CARD_LABEL=8600 0000 0000 0000
MANUAL_PAYMENT_PLAN_DAYS=30
ADMIN_APPROVAL_TOKEN=replace-with-private-admin-token
